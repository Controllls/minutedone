# ============================================================
# 팀 라이브러리 에이전트 v2 - 환경변수 설정 파일
# ============================================================
# 사용법: cp config/.env.template config/.env  후 키를 입력하세요.
# ⚠️  .env 파일은 절대 Git에 커밋하지 마세요!
# ============================================================

# ------ 사용할 LLM 선택 ------
# claude / chatgpt / gemini / local 중 하나 입력
LLM_PROVIDER=claude

# ------ Anthropic (Claude) ------
ANTHROPIC_API_KEY=

# ------ OpenAI (ChatGPT) ------
OPENAI_API_KEY=

# ------ Google (Gemini) ------
GOOGLE_API_KEY=

# ------ 로컬 LLM (Ollama) ------
# LLM_PROVIDER=local 일 때 사용합니다.
# 사전 준비: ollama 설치 → ollama pull llama3.1 → ollama serve
LOCAL_MODEL=llama3.1
LOCAL_BASE_URL=http://localhost:11434

# ------ Google Sheets ------
GOOGLE_SHEET_ID=

# ------ Notion ------
NOTION_TOKEN=
NOTION_MEETINGS_DB_ID=

# ------ 모델 설정 (변경하지 않아도 됩니다) ------
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-1.5-pro

# ------ 로그 레벨 ------
LOG_LEVEL=INFO
